SECRET_KEY=your-super-secret-key-change-this-in-production-xyz123
JWT_SECRET_KEY=jwt-super-secret-token-change-this-too-abc456
DATABASE_URL=sqlite:///interview_coach_enterprise.db
FLASK_ENV=development

# ═══════════════════════════════════════════════════════════════════════════════
# MISTRAL AI / LM STUDIO CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# This application uses Mistral AI for intelligent question generation and answer
# evaluation. You have two options:
#
# OPTION A: Local (Recommended for Privacy & Offline)
# ──────────────────────────────────────────────────
# Uses LM Studio: https://lmstudio.ai/
# - Download and install LM Studio
# - Load "mistral-7b-instruct-v0.2" model
# - Start local server on http://127.0.0.1:1234/v1
# - No API key needed, completely offline, free
#
# OPTION B: Cloud (Recommended for Speed & Lower Resources)
# ────────────────────────────────────────────────────────
# Uses Mistral AI Cloud API: https://console.mistral.ai/
# - Sign up and get API key
# - Change MISTRAL_BASE_URL to: https://api.mistral.ai/v1
# - Change MISTRAL_MODEL_NAME to: mistral-small (or mistral-medium/mistral-large)
# - Pay per request (very affordable)

# ── LOCAL SETUP (LM Studio) ─────────────────────────────────────────────────────
MISTRAL_BASE_URL=http://127.0.0.1:1234/v1
MISTRAL_MODEL_NAME=mistral-7b-instruct-v0.2
MISTRAL_API_KEY=lm-studio

# ── CLOUD SETUP (Optional - Mistral AI API) ────────────────────────────────────
# Uncomment these lines to use cloud API instead:
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_MODEL_NAME=mistral-small
# MISTRAL_API_KEY=your_api_key_from_console_mistral_ai

# ═══════════════════════════════════════════════════════════════════════════════
# FALLBACK BEHAVIOR
# ═══════════════════════════════════════════════════════════════════════════════
# If Mistral AI is offline or unavailable:
# ✓ Application continues running with fallback mode
# ✓ Mock interviews use pre-loaded high-quality questions
# ✓ MC options are generated locally with smart distractors
# ✓ Answers evaluated using heuristic scoring (word count + patterns)
# ✗ AI-powered detailed feedback not available
#
# The application automatically detects when Mistral comes online
# and seamlessly transitions to AI-powered mode within 5-120 seconds.
# ═════════════════════════════════════════════════════════════════════════════════